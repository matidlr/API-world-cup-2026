# Swagger
SWAGGER_APP_TITLE=World Cup API
SWAGGER_APP_DESCRIPTION=World Cup API for Programacion III TP
SWAGGER_APP_VERSION=1.0.0
#Options: classic | dark
SWAGGER_THEME=dark

# App
APP_PORT=5101
APP_BASE_PATH=worldCup
APP_LOG_LEVEL=log
CORS_ALLOWED_ORIGIN=http://localhost:5300

# SQLite
DB_TYPE=sqlite
DB_DATABASE=./database/world_cup_api.db

# World Cup
WORLD_CUP_EDITION=2026

# Smoke tests use .env.smoke (default APP_PORT=4101)

# Match config

# Match turns (optional override, minimum effective value is 5)
MAX_TURNS_PER_MATCH=10
# Match response messages per turn (clamped between 2 and 20)
MAX_MESSAGES_PER_TURN=15
# Max substitutions per team in one match
MAX_MATCH_SUBSTITUTIONS_PER_TEAM=5
# Auto-adjust team formation after a user strategy change when the current formation is incompatible
AUTO_ADJUST_FORMATION_ON_STRATEGY_CHANGE=true

# Opponent AI tactical engine

# If true, the AI will only start changing its strategy in the second half
OPPONENT_TACTICS_ONLY_SECOND_HALF_ENABLED=true
# Number of turns the AI waits before changing strategy again
OPPONENT_TACTICS_COOLDOWN_TURNS=1
# Maximum number of strategy changes the AI can make during the match
OPPONENT_MAX_STRATEGY_CHANGES_PER_MATCH=5

# AI Coach

# Coach style influence when selecting compatible formations (0..10)
# 0: context-only (pragmatic), 10: coach-style-only
COACH_FORMATION_STYLE_STRICTNESS=6
